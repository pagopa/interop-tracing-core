{
  "name": "pagopa-interop-tracing-commons",
  "private": true,
  "version": "1.0.0",
  "description": "PagoPA Interoperability tracing common utilities",
  "main": "dist",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "lint": "eslint .  ",
    "lint:autofix": "eslint . --fix",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "start": "node --watch --no-warnings --loader ts-node/esm ./src/index.ts",
    "build": "tsc",
    "check": "tsc --project tsconfig.check.json"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-sdk/client-s3": "3.887.0",
    "@aws-sdk/client-sqs": "3.887.0",
    "@aws-sdk/lib-storage": "3.887.0",
    "@zodios/core": "10.9.6",
    "@zodios/express": "10.6.1",
    "csv-parser": "3.0.0",
    "connection-string": "4.4.0",
    "express-winston": "4.2.0",
    "kafkajs": "2.2.4",
    "pagopa-interop-tracing-models": "workspace:*",
    "pg-promise": "11.7.8",
    "ts-pattern": "5.4.0",
    "uuid": "10.0.0",
    "winston": "3.9.0",
    "zod": "3.23.8",
    "zod-validation-error": "3.3.0"
  },
  "devDependencies": {
    "@types/express": "4.17.17",
    "@types/node": "20.10.0",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "8.22.0",
    "@typescript-eslint/parser": "8.22.0",
    "eslint": "9.18.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.0",
    "globals": "15.14.0",
    "prettier": "3.0.3",
    "ts-node": "10.9.2",
    "typescript": "5.5.2"
  }
}