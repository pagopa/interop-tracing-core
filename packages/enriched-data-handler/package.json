{
  "name": "pagopa-interop-tracing-enriched-data-handler",
  "version": "1.0.0",
  "description": "PagoPA tracing enriched data handler",
  "main": "dist",
  "type": "module",
  "scripts": {
    "test": "vitest --config ./test/vitest.config.ts",
    "test:it": "vitest db --config ./test/vitest.config.ts",
    "lint": "eslint .  ",
    "lint:autofix": "eslint . --fix",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "start": "node  --no-warnings --loader ts-node/esm -r 'dotenv-flow/config' ./src/index.ts",
    "build": "tsc",
    "check": "tsc --project tsconfig.check.json"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.22.0",
    "@typescript-eslint/parser": "8.22.0",
    "@types/dotenv-flow": "3.3.3",
    "@types/node": "20.10.0",
    "@types/uuid": "9.0.8",
    "camelcase-keys": "9.1.3",
    "ts-node": "10.9.2",
    "typescript": "5.5.2",
    "testcontainers": "10.2.2",
    "vitest": "0.33.0",
    "eslint": "9.18.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.0",
    "globals": "15.14.0",
    "prettier": "3.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.887.0",
    "@tsconfig/node-lts": "20.1.0",
    "dotenv-flow": "3.3.0",
    "pagopa-interop-tracing-commons": "workspace:*",
    "pagopa-interop-tracing-models": "workspace:*",
    "p-retry": "6.2.1",
    "pg-promise": "11.8.0",
    "ts-pattern": "5.4.0",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  }
}