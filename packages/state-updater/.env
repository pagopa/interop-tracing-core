APPLICATION_NAME="interop-tracing-state-updater"
LOG_LEVEL=info

AWS_REGION="eu-central-1"
SQS_ENDPOINT="http://localhost:9324"
SQS_PROCESSING_RESULTS_ENDPOINT="http://localhost:9324/000000000000/processing-results"
CONSUMER_POLLING_TIMEOUT_IN_SECONDS="3"

AWS_CONFIG_FILE=aws.config.local

S3_TRACING_ERRORS_BUCKET_NAME="interop-tracing-errors-bucket"
S3_CUSTOM_SERVER=true
S3_SERVER_HOST=http://localhost
S3_SERVER_PORT=9000

TRACING_STORE_DB_HOST=127.0.0.1
TRACING_STORE_DB_NAME=tracing_db
TRACING_STORE_DB_USERNAME=mydbuser
TRACING_STORE_DB_PASSWORD=mypassword
TRACING_STORE_DB_PORT=55000
TRACING_STORE_DB_USE_SSL=false
TRACING_STORE_DB_SCHEMA_NAME=tracing
