APPLICATION_NAME="interop-tracing-state-updater"
LOG_LEVEL=info

AWS_REGION="eu-central-1"
SQS_ENDPOINT="http://localhost:9324"
SQS_ENDPOINT_PROCESSING_ERROR_QUEUE="http://localhost:9324/000000000000/processing-error"
SQS_ENDPOINT_ENRICHER_STATE_QUEUE="http://localhost:9324/000000000000/enricher-state"
CONSUMER_POLLING_TIMEOUT_IN_SECONDS="3"

AWS_CONFIG_FILE=aws.config.local

DB_HOST=127.0.0.1
DB_NAME=tracing_db
DB_USERNAME=mydbuser
DB_PASSWORD=mypassword
DB_PORT=55000
DB_USE_SSL=false
DB_SCHEMA_NAME=tracing
